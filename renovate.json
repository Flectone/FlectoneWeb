{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "labels": ["dependencies"],
  "semanticCommitType": "build",
  "commitMessagePrefix": "chore(deps): ",
  "enabledManagers": ["npm"],
  "ignorePaths": ["**/package.json", "!package.json"],
  "rangeStrategy": "bump" 
}
